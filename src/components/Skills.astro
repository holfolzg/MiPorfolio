---
import skills from '../data/skills.json';
---

<section class="skills" id="skills">
  <div class="skills-container">

    <p class="skills-label">Tecnologías</p>
    <h2 class="skills-title">Mis skills</h2>

    <div class="skills-grid">
      {skills.skills.map((skill) => (
        <div class="skill-card">
          <img src={skill.icono} alt={skill.nombre} class="skill-icon" />
          <span class="skill-name">{skill.nombre}</span>
        </div>
      ))}
    </div>

  </div>
  </section>

  <style>
    .skills {
      padding: var(--section-gap) 1.5rem;
    }

    .skills-container {
      width: 100%;
      max-width: var(--max-width);
      margin: 0 auto;
    }

    .skills-label {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-accent);
      margin-bottom: 0.5rem;
    }

    .skills-title {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      margin-bottom: 2.5rem;
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 1rem;
    }

    .skill-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem 0.75rem;
      border: 1px solid var(--color-border);
      border-radius: 12px;
      background: var(--color-surface);
      transition: all var(--transition-base);
      cursor: default;
    }

    .skill-card:hover {
      border-color: var(--color-purple);
      background: var(--color-surface-2);
      transform: translateY(-4px);
      box-shadow: 0 8px 24px var(--color-purple-glow);
    }

    .skill-icon {
      width: 36px;
      height: 36px;
      object-fit: contain;
    }

    .skill-name {
      font-size: 0.75rem;
      font-family: var(--font-mono);
      color: var(--color-text-muted);
      text-align: center;
    }

    /* ─── RESPONSIVE ─── */

    @media (max-width: 768px) {
      .skills {
        padding: 4rem 1.2rem;
      }

      .skills-grid {
        grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
        gap: 0.75rem;
      }

      .skill-icon {
        width: 28px;
        height: 28px;
      }

      .skill-name {
        font-size: 0.7rem;
      }
    }

    @media (max-width: 400px) {
      .skills-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
  </style>
